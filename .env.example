# Copy this to .env for local development
# On Railway, set these in the Variables tab (NOT this file)

NODE_ENV=production
PORT=3001

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-64-char-hex-string

# DB path — Railway volume must be mounted at /app/data
# Local default (no DB_PATH needed): ./data/sheet.db
DB_PATH=/app/data/sheet.db

# Override default users on first boot (format: user:pass:role,...)
# REQUIRED on Railway — default passwords admin123/bd2025 are too weak for production
USERS=admin:YourStrongAdminPass!2025:admin,belgiumd:YourStrongUserPass!2025:user
