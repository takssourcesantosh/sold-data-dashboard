# Copy to .env on the server. Never commit .env.

NODE_ENV=production
PORT=3001

# Generate a new secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-64-char-hex-string

# DB path — local VPS default: ./data/sheet.db (relative to project root)
# Override only if you want a custom path e.g. /var/data/sold-dashboard/sheet.db
# DB_PATH=./data/sheet.db

# Override default users on first boot (format: user:pass:role,...)
# REQUIRED — default passwords are too weak for production
USERS=admin:YourStrongAdminPass!2025:admin,belgiumd:YourStrongUserPass!2025:user
